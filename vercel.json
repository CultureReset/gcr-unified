{
  "version": 2,
  "buildCommand": "npm run build",
  "framework": "vite",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/bookpro",
      "destination": "/bookpro/index.html"
    },
    {
      "source": "/bookpro/start",
      "destination": "/bookpro/start.html"
    },
    {
      "source": "/bookpro/dashboard",
      "destination": "/bookpro/dashboard.html"
    },
    {
      "source": "/:slug/profile",
      "destination": "/song-request.html?slug=:slug"
    },
    {
      "source": "/p/:slug",
      "destination": "/biz.html"
    },
    {
      "source": "/book/:slug/:app",
      "destination": "/book.html"
    },
    {
      "source": "/u/:code",
      "destination": "/user.html"
    },
    {
      "source": "/r/:slug",
      "destination": "/verified-review.html"
    },
    {
      "source": "/reviews/:slug",
      "destination": "/review-wall.html"
    },
    {
      "source": "/manage/:id",
      "destination": "/manage.html"
    },
    {
      "source": "/waiver/:slug",
      "destination": "/waiver.html"
    },
    {
      "source": "/developers/reviews",
      "destination": "/reviews-api.html"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}